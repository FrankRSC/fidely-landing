{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://fidely-backend-production.up.railway.app/:path*"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
